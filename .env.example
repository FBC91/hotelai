# =============================================================================
# Hotel AI · variables de entorno
# =============================================================================
# 1. Copiá este archivo a `.env`
# 2. Rellená los valores reales
# 3. NUNCA comitees `.env` al repo (ya está en .gitignore)
# 4. Si una key se filtra: rotala en la consola del provider INMEDIATAMENTE
# =============================================================================

# ─── ETAPA 1 (schemas + SQL + state) ─────────────────────────────────────────
# Esta etapa no requiere variables externas. Solo Python local.

# ─── ETAPA 3+ · LLMs Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

CONCIERGE_MODEL=claude-sonnet-4-6
LIFECYCLE_MODEL=claude-sonnet-4-6
HAIKU_MODEL=claude-haiku-4-5-20251001

# ─── ETAPA 4+ · Supabase (proyecto: HotelIA) ─────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_ANON_KEY=sb_publishable_...

# Connection string directa para el checkpointer de LangGraph
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ─── Canal · Email (Gmail SMTP/IMAP) ─────────────────────────────────────────
# Casilla compartida del hotel
GMAIL_USER=hotelia2026@gmail.com
# App Password (16 chars). Generarlo en https://myaccount.google.com/apppasswords
# Requiere 2FA habilitado en la cuenta.
GMAIL_APP_PASSWORD=

GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_POLL_SECONDS=30

# ─── Canal · Web chat (simulador WhatsApp en facundobolani.com) ──────────────
# URL del backend que recibe los mensajes del simulador
WEB_CHAT_API_BASE_URL=http://localhost:8000
# Secreto HMAC para firmar requests del frontend → backend
WEB_CHAT_HMAC_SECRET=
# Origen permitido para CORS (el frontend)
WEB_CHAT_ALLOWED_ORIGIN=https://facundobolani.com

# ─── Política operativa ──────────────────────────────────────────────────────
HOTEL_NAME=Hotel Bahía Serena
TZ=America/Montevideo
DEFAULT_LANGUAGE=es

# Pago manual (sin gateway real)
PAYMENT_REMINDER_HOURS=6
PAYMENT_MAX_REMINDERS=2
PAYMENT_HOLD_TTL_HOURS=24

# Refunds: el agente puede ejecutar hasta este monto sin humano
REFUND_AUTO_CAP_USD=200

# Rate limiting por huésped (entrante)
RATE_LIMIT_MSG_PER_MIN=30
RATE_LIMIT_MSG_PER_HOUR=200

# ─── Observabilidad ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
